@{
    var isAuth = User?.Identity?.IsAuthenticated ?? false;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة التحكم</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { background:#f4f6f9; }
        .admin-sidebar { min-height:100vh; background:#0f5132; }
        .admin-sidebar .nav-link { color:#d7e9df; border-radius:.5rem; margin-bottom:.25rem; }
        .admin-sidebar .nav-link:hover, .admin-sidebar .nav-link.active { background:rgba(255,255,255,.12); color:#fff; }
        .admin-brand { color:#fff; font-weight:700; }
    </style>
</head>
<body>
@if (isAuth)
{
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 d-md-block admin-sidebar p-3">
                <div class="admin-brand fs-5 mb-4"><i class="bi bi-water"></i> لوحة المؤتمر</div>
                <ul class="nav flex-column">
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> الرئيسية</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Registrations" asp-action="Individuals"><i class="bi bi-people"></i> تسجيل الأفراد</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Registrations" asp-action="Sponsors"><i class="bi bi-building"></i> الرعاة</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Settings" asp-action="Index"><i class="bi bi-clock"></i> وقت المؤتمر</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="About" asp-action="Index"><i class="bi bi-info-circle"></i> عن المؤتمر</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Objectives" asp-action="Index"><i class="bi bi-bullseye"></i> أهداف المؤتمر</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Agenda" asp-action="Index"><i class="bi bi-list-check"></i> الأجندة</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Admin" asp-controller="Speakers" asp-action="Index"><i class="bi bi-mic"></i> المتحدثون</a></li>
                </ul>
                <hr class="text-white-50" />
                <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn btn-outline-light btn-sm w-100"><i class="bi bi-box-arrow-right"></i> تسجيل الخروج</button>
                </form>
            </nav>
            <main class="col-md-9 col-lg-10 p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">@TempData["Success"]</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">@TempData["Error"]</div>
                }
                @RenderBody()
            </main>
        </div>
    </div>
}
else
{
    <div class="container py-5">
        @RenderBody()
    </div>
}
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
